# Azure AI Foundry Project Configuration
# Copy this file to .env and fill in your values

# Your Azure AI Foundry project endpoint URL
PROJECT_ENDPOINT=https://your-project.services.ai.azure.com/api/projects/your-project-id

# The name of your model deployment in the project
MODEL_DEPLOYMENT_NAME=your-model-deployment-name

# Optional: Browser automation project connection ID (if using browser tools)
BROWSER_AUTOMATION_PROJECT_CONNECTION_ID=

# Optional: Azure Blob URI for screenshots or other assets
AZURE_BLOB_URI=

# Optional: MCP Server URL (if using Model Context Protocol)
MCP_SERVER_URL=

# Optional: MCP Server Label
MCP_SERVER_LABEL=

# Optional: Application Insights connection string for telemetry
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Optional: OpenTelemetry setting for capturing message content
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=true